<?xml version="1.0" encoding="UTF-8"?>
<!--
  Message-start BPMN — splat → mesh bake (gsplat PLY → TSDF mesh GLB).

  ADR-2605092800 §D6. The maps-ui CF Worker publishes the start
  message (`com.etzhayyim.apps.maps.bakeGsplatAsset`) from the
  `cmdBakeGsplatAsset` XRPC handler. correlationKey = tileH3 so
  concurrent bake requests for the same tile collapse to one job.

  NSID: com.etzhayyim.apps.maps.bakeGsplatAsset
  vertex_id: at://did:web:bpmn.etzhayyim.com/com.etzhayyim.apps.bpmn.processDef/maps-bake-gsplat-asset-v1
-->
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
    id="Definitions_maps_bake_gsplat_asset"
    targetNamespace="https://etzhayyim.ai/bpmn/maps"
    exporter="hand-written"
    exporterVersion="1.0">
  <bpmn:process id="maps_bake_gsplat_asset"
                name="maps bake gsplat asset" isExecutable="true">

    <bpmn:documentation>
      { "nsid": "com.etzhayyim.apps.maps.bakeGsplatAsset", "version": 1, "resultTimeoutMs": 1800000 }
    </bpmn:documentation>

    <bpmn:startEvent id="Start_Message" name="com.etzhayyim.apps.maps.bakeGsplatAsset">
      <bpmn:outgoing>Flow_Start</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Start"
                                   messageRef="Msg_BakeGsplatAsset"/>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Start" sourceRef="Start_Message" targetRef="Task_Trigger"/>

    <bpmn:serviceTask id="Task_Trigger" name="POST /trigger/bake to gsplat-train dumper pod">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.http.fetch"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;http://bulk-ingest-gsplat-train.maps-bulk-ingest.svc.cluster.local:8080/trigger/bake&quot;" target="url"/>
          <zeebe:input source="=&quot;POST&quot;"                target="method"/>
          <zeebe:input source="=&quot;application/json&quot;"    target="contentType"/>
          <zeebe:input source="={ mode: &quot;bake&quot;, bakeJobId: bakeJobId, tileH3: tileH3, vertexId: vertexId, targetTriangles: targetTriangles, priority: priority }" target="body"/>
          <zeebe:input source="=30000"                           target="timeoutMs"/>
          <zeebe:output source="=status"   target="triggerStatus"/>
          <zeebe:output source="=bodyJson" target="triggerResult"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start</bpmn:incoming>
      <bpmn:outgoing>Flow_Audit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_Audit" sourceRef="Task_Trigger" targetRef="Task_Audit"/>

    <bpmn:serviceTask id="Task_Audit" name="emit gsplat.bake.triggered OCEL">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.audit.emit"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;com.etzhayyim.apps.maps.gsplat.bake.triggered&quot;" target="eventType"/>
          <zeebe:input source="={ bakeJobId: bakeJobId, tileH3: tileH3, vertexId: vertexId, status: triggerStatus }" target="attributes"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Audit</bpmn:incoming>
      <bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Task_Audit" targetRef="End"/>

    <bpmn:endEvent id="End" name="dispatched">
      <bpmn:incoming>Flow_End</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <bpmn:message id="Msg_BakeGsplatAsset"
                name="com.etzhayyim.apps.maps.bakeGsplatAsset">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=tileH3"/>
    </bpmn:extensionElements>
  </bpmn:message>
</bpmn:definitions>
