{"lexicon" 1, "id" "com.etzhayyim.maps.naturalZone", "description" "Natural zone record — Köppen climate (5), WWF biome (14), or tectonic plate (15) = 34 canonical zones per maps CLAUDE.md §Layer 3. Constants under decadal revision cadence. Per ADR-2605231400 + maps MIGRATION-TODO Phase 1 (Tier A).", "defs" {"main" {"type" "record", "key" "literal:{slug}", "record" {"type" "object", "required" ["v" "slug" "kind" "code" "name" "registeredAt"], "properties" {"v" {"type" "integer", "minimum" 1, "maximum" 1}, "slug" {"type" "string", "description" "kebab-case '{kind}-{code}' (e.g., 'koppen-af', 'biome-tropical-broadleaf').", "minLength" 1, "maxLength" 96}, "kind" {"type" "string", "knownValues" ["koppen" "biome" "tectonic"]}, "code" {"type" "string", "description" "Scheme-native code (e.g., 'Af' for Köppen tropical rainforest, '1' for WWF biome tropical broadleaf, 'NA' for North American plate).", "minLength" 1, "maxLength" 32}, "name" {"type" "string", "minLength" 1, "maxLength" 128}, "description" {"type" "string", "maxLength" 1024}, "registeredAt" {"type" "string", "format" "datetime"}}}}}}